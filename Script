local function copyToClipboard(text)
	local copied = false

	if typeof(setclipboard) == "function" then
		pcall(function()
			setclipboard(text)
			copied = true
		end)
	end

	if not copied and typeof(writeclipboard) == "function" then
		pcall(function()
			writeclipboard(text)
			copied = true
		end)
	end

	if not copied and typeof(Clipboard) == "table" and typeof(Clipboard.set) == "function" then
		pcall(function()
			Clipboard.set(text)
			copied = true
		end)
	end

	return copied
end

--========================================================
-- HTTP KEY SYSTEM CONFIG
--========================================================
-- Works in two modes:
-- 1) Your own game: add GoldhaxKeyValidator.server.lua to ServerScriptService; client uses RemoteFunction.
-- 2) Executor in someone else's game: no server script, so we use the executor's HTTP (syn.request, request, etc.) to call the site.

local YOUR_WEBSITE = "https://www.goldhax.space"

-- Cached remote (only used if game has the server validator script)
local validateRemote = nil

-- Try executor HTTP (for when you're not the server owner / running in an executor)
local function validateWithExecutorHttp(keyTrimmed, userIdStr)
	local url = YOUR_WEBSITE .. "/validate?key=" .. HttpService:UrlEncode(keyTrimmed) .. "&userId=" .. HttpService:UrlEncode(userIdStr)
	local body = nil
	-- Synapse / Synapse X
	if syn and syn.request then
		local ok, res = pcall(function()
			return syn.request({ Url = url, Method = "GET" })
		end)
		if ok and res and res.Body then body = res.Body end
	end
	-- Other executors (KRNL, Fluxus, etc. often expose request())
	if not body and type(request) == "function" then
		local ok, res = pcall(function()
			return request({ Url = url, Method = "GET" })
		end)
		if ok and res then
			if type(res) == "string" then body = res
			elseif res.Body then body = res.Body end
		end
	end
	if not body and type(http_request) == "function" then
		local ok, res = pcall(function()
			return http_request({ Url = url, Method = "GET" })
		end)
		if ok and res and res.Body then body = res.Body end
	end
	if not body then return false, nil end
	local ok, data = pcall(HttpService.JSONDecode, HttpService, body)
	if not ok or not data then return false, nil end
	if data.valid == true then
		return true, data.expiry
	end
	return false, nil
end

-- Validate key: try game server RemoteFunction first, then executor HTTP.
-- Returns valid, expiry, errMsg (errMsg = "no_remote" when neither method is available)
local function validateKeyWithServer(key, userId)
	local keyTrimmed = (key and key:gsub("^%s+", ""):gsub("%s+$", "") or "")
	if keyTrimmed == "" then
		return false, nil
	end
	keyTrimmed = keyTrimmed:lower()
	local userIdStr = tostring(userId)

	-- 1) Try game server (if they added GoldhaxKeyValidator.server.lua)
	if not validateRemote then
		validateRemote = ReplicatedStorage:FindFirstChild("GoldhaxValidateKey")
		if not validateRemote then
			validateRemote = ReplicatedStorage:WaitForChild("GoldhaxValidateKey", 3)
		end
	end
	if validateRemote then
		local ok, valid, expiry = pcall(function()
			return validateRemote:InvokeServer(keyTrimmed)
		end)
		if ok and valid then
			return true, expiry
		end
	end

	-- 2) Fallback: executor HTTP (for exploit / not server owner)
	local valid, expiry = validateWithExecutorHttp(keyTrimmed, userIdStr)
	if valid then
		return true, expiry
	end

	-- Neither available
	return false, nil, "no_remote"
end

