local espEnabled = false
local espHighlights = {}
local espConnections = {}

local function clearESP()
	for _, h in ipairs(espHighlights) do
		if h and h.Parent then
			h:Destroy()
		end
	end
	espHighlights = {}
	for _, c in ipairs(espConnections) do
		pcall(function()
			c:Disconnect()
		end)
	end
	espConnections = {}
end

local function attachHighlightToCharacter(character)
	if not character then return end
	if character:FindFirstChildOfClass("Highlight") then return end
	local h = Instance.new("Highlight")
	h.FillTransparency = 1
	h.OutlineTransparency = 0
	h.OutlineColor = accentBlue
	h.Adornee = character
	h.Parent = character
	table.insert(espHighlights, h)
end

local function enableESP()
	clearESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player then
			attachHighlightToCharacter(plr.Character)
			table.insert(espConnections, plr.CharacterAdded:Connect(function(char)
				if espEnabled then
					attachHighlightToCharacter(char)
				end
			end))
		end
	end
end

local function disableESP()
	clearESP()
end

local function getHumanoid()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:FindFirstChildOfClass("Humanoid"), char
end

-- fly
local flying = false
local flyBV
local flyConn
local inputBeganConn
local inputEndedConn

local keysDown = {
	W = false,
	A = false,
	S = false,
	D = false,
	Space = false,
	LeftShift = false,
}

inputBeganConn = UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local key = input.KeyCode.Name
		if keysDown[key] ~= nil then
			keysDown[key] = true
		end
	end
end)

inputEndedConn = UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local key = input.KeyCode.Name
		if keysDown[key] ~= nil then
			keysDown[key] = false
		end
	end
end)

local function setFlying(enabled)
	if flying == enabled then return end
	flying = enabled

	local hum, char = getHumanoid()
	if not hum or not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	if flying then
		flyBV = Instance.new("BodyVelocity")
		flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
		flyBV.Velocity = Vector3.zero
		flyBV.Parent = hrp

		hum.PlatformStand = true

		flyConn = RunService.RenderStepped:Connect(function()
			if not flying or not flyBV or not flyBV.Parent then return end
			local cam = workspace.CurrentCamera
			if not cam then return end
			local dir = Vector3.zero
			local cf = cam.CFrame
			if keysDown.W then dir += cf.LookVector end
			if keysDown.S then dir -= cf.LookVector end
			if keysDown.A then dir -= cf.RightVector end
			if keysDown.D then dir += cf.RightVector end
			if keysDown.Space then dir += Vector3.new(0, 1, 0) end
			if keysDown.LeftShift then dir -= Vector3.new(0, 1, 0) end
			if dir.Magnitude > 0 then dir = dir.Unit end
			flyBV.Velocity = dir * 60
		end)
	else
		if flyBV then flyBV:Destroy() flyBV = nil end
		if flyConn then flyConn:Disconnect() flyConn = nil end
		hum.PlatformStand = false
	end
end

