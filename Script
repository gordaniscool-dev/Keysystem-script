local activeNotification

local function showNotification(message)
	if activeNotification then
		activeNotification:Destroy()
		activeNotification = nil
	end

	local notif = Instance.new("Frame")
	notif.Name = "GoldhaxNotification"
	notif.AnchorPoint = Vector2.new(1, 1)
	notif.Size = UDim2.fromOffset(260, 60)
	notif.Position = UDim2.new(1, -20, 1, 20)
	notif.BackgroundColor3 = rgb(16, 17, 20)
	notif.BackgroundTransparency = 1
	notif.Parent = gui
	makeCorner(notif, 10)
	makeStroke(notif, 1, rgb(60, 64, 74), 0.5)

	local text = makeLabel(notif, {
		Text = message,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = rgb(235, 235, 235),
		Position = UDim2.fromOffset(12, 8),
		Size = UDim2.new(1, -40, 1, -16),
		TextYAlignment = Enum.TextYAlignment.Top,
	})
	text.TextTransparency = 1

	local closeBtn = Instance.new("TextButton")
	closeBtn.AutoButtonColor = false
	closeBtn.AnchorPoint = Vector2.new(1, 0)
	closeBtn.Size = UDim2.fromOffset(18, 18)
	closeBtn.Position = UDim2.new(1, -8, 0, 8)
	closeBtn.BackgroundColor3 = rgb(32, 35, 44)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Text = "X"
	closeBtn.TextColor3 = rgb(235, 235, 235)
	closeBtn.TextSize = 12
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Parent = notif
	makeCorner(closeBtn, 6)
	closeBtn.TextTransparency = 1

	activeNotification = notif

	tween(notif, 0.4, { Position = UDim2.new(1, -20, 1, -20), BackgroundTransparency = 0.25 })
	tween(text, 0.35, { TextTransparency = 0 })

	local hovering = false
	local closed = false

	local function fadeOutAndDestroy()
		if closed then return end
		closed = true
		local t1 = tween(notif, 0.3, { Position = UDim2.new(1, -20, 1, 20), BackgroundTransparency = 1 }, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
		tween(text, 0.2, { TextTransparency = 1 }, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
		tween(closeBtn, 0.18, { TextTransparency = 1, BackgroundTransparency = 1 }, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
		t1.Completed:Wait()
		if notif.Parent then
			notif:Destroy()
		end
		if activeNotification == notif then
			activeNotification = nil
		end
	end

	notif.MouseEnter:Connect(function()
		hovering = true
		tween(closeBtn, 0.2, { TextTransparency = 0, BackgroundTransparency = 0.2 })
	end)

	notif.MouseLeave:Connect(function()
		hovering = false
		tween(closeBtn, 0.2, { TextTransparency = 1, BackgroundTransparency = 1 })
	end)

	closeBtn.MouseButton1Click:Connect(function()
		fadeOutAndDestroy()
	end)

	task.delay(3, function()
		if not hovering then
			fadeOutAndDestroy()
		end
	end)
end

