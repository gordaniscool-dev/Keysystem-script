-- slider helper
local function makeSlider(parent, options)
	local sliderFrame = Instance.new("Frame")
	sliderFrame.BackgroundTransparency = 1
	sliderFrame.Size = UDim2.new(1, 0, 0, 40)
	sliderFrame.Parent = parent

	makeLabel(sliderFrame, {
		Text = options.Label or "Slider",
		TextSize = 13,
		TextColor3 = rgb(210, 210, 210),
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.fromOffset(160, 18),
	})

	local valueLabel = makeLabel(sliderFrame, {
		Text = tostring(options.Default or options.Min),
		TextSize = 13,
		TextColor3 = rgb(190, 190, 190),
		Position = UDim2.fromOffset(170, 0),
		Size = UDim2.fromOffset(90, 18),
	})

	local bar = Instance.new("Frame")
	bar.BackgroundColor3 = rgb(40, 42, 50)
	bar.BackgroundTransparency = 0.3
	bar.Size = UDim2.new(1, -10, 0, 6)
	bar.Position = UDim2.fromOffset(0, 26)
	bar.Parent = sliderFrame
	makeCorner(bar, 3)

	local fill = Instance.new("Frame")
	fill.BackgroundColor3 = accentBlue
	fill.BackgroundTransparency = 0.15
	fill.Size = UDim2.fromOffset(0, 6)
	fill.Parent = bar
	makeCorner(fill, 3)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(12, 12)
	knob.BackgroundColor3 = rgb(235, 235, 235)
	knob.Parent = bar
	makeCorner(knob, 999)

	local dragging = false
	local min = options.Min or 0
	local max = options.Max or 100
	local current = options.Default or min

	local function updateFromPercent(p)
		p = math.clamp(p, 0, 1)
		current = min + (max - min) * p
		local px = math.floor(p * bar.AbsoluteSize.X)
		fill.Size = UDim2.fromOffset(px, 6)
		knob.Position = UDim2.fromOffset(px - 6, -3)
		valueLabel.Text = string.format("%.1f", current)
		if options.OnChanged then
			options.OnChanged(current)
		end
	end

	local function inputToPercent(input)
		local relX = input.Position.X - bar.AbsolutePosition.X
		return relX / math.max(1, bar.AbsoluteSize.X)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateFromPercent(inputToPercent(input))
		end
	end)
	bar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateFromPercent(inputToPercent(input))
		end
	end)

	task.defer(function()
		updateFromPercent((current - min) / (max - min))
	end)

	return {
		GetValue = function()
			return current
		end,
	}
end

