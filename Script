local function setActive(name)
	activeName = name
	for _, page in ipairs(pages:GetChildren()) do
		if page:IsA("Frame") then
			page.Visible = (page.Name == name)
		end
	end
	for n, btn in pairs(navButtons) do
		if n == name then
			btn.BackgroundColor3 = rgb(40, 42, 50)
			tween(btn, 0.15, { BackgroundTransparency = 0.15 })
			btn.TextColor3 = rgb(235, 235, 235)
		else
			tween(btn, 0.15, { BackgroundTransparency = 1 })
			btn.TextColor3 = rgb(180, 180, 180)
		end
	end
end

local function makeNavButton(text)
	local btn = Instance.new("TextButton")
	btn.AutoButtonColor = false
	btn.Text = text
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 13
	btn.TextXAlignment = Enum.TextXAlignment.Left
	btn.TextColor3 = rgb(180, 180, 180)
	btn.BackgroundColor3 = rgb(32, 34, 42)
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1, 0, 0, 34)
	btn.Parent = nav
	makeCorner(btn, 8)
	makePadding(btn, 12, 10, 0, 0)

	btn.MouseEnter:Connect(function()
		if activeName ~= text then
			tween(btn, 0.14, { BackgroundTransparency = 0.35 })
		end
	end)
	btn.MouseLeave:Connect(function()
		if activeName ~= text then
			tween(btn, 0.14, { BackgroundTransparency = 1 })
		end
	end)

	btn.MouseButton1Click:Connect(function()
		if not hasKey and (text == "Scripts" or text == "Player") then
			showNotification("Enter a valid key first.")
			return
		end
		setActive(text)
	end)

	return btn
end

