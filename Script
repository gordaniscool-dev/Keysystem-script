local function setMinimized(minimize)
	if minimize and not isMinimized then
		isMinimized = true
		originalSize = root.Size
		originalPosition = root.Position
		originalAbsTopLeft = root.AbsolutePosition
		originalAbsSize = root.AbsoluteSize

		content.Visible = false

		root.AnchorPoint = Vector2.new(0, 0)
		root.Position = UDim2.fromOffset(originalAbsTopLeft.X, originalAbsTopLeft.Y)
		root.Size = UDim2.fromOffset(originalAbsSize.X, originalAbsSize.Y)

		tween(root, 0.45, { Size = UDim2.fromOffset(260, 46) }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	elseif not minimize and isMinimized then
		isMinimized = false

		local t = tween(root, 0.45, { Size = UDim2.fromOffset(originalAbsSize.X, originalAbsSize.Y) }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		t.Completed:Wait()

		root.AnchorPoint = Vector2.new(0.5, 0.5)
		root.Size = originalSize
		root.Position = originalPosition
		content.Visible = true
	end
end

